{
	"name": "promptbox",
	"version": "1.1.1",
	"description": "Obsidian plugin: local-first library of AI prompts with categorization, search, and quick reuse.",
	"main": "main.js",
	"private": true,
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit",
		"lint": "eslint .",
		"test": "vitest run"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"prompts"
	],
	"author": "Stefano Ferri",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"obsidian": "^1.13.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vitest": "^4.1.9"
	}
}
